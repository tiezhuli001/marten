APP_ENV=development
APP_NAME=marten
APP_PORT=8000
APP_DATA_DIR=data
DATABASE_URL=sqlite:///data/marten.db

LANGSMITH_TRACING=false
LANGSMITH_PROJECT=marten
LANGSMITH_API_KEY=

# Secrets
OPENAI_API_KEY=
MINIMAX_API_KEY=
GITHUB_TOKEN=
CHANNEL_WEBHOOK_URL=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
GITLAB_TOKEN=

# Optional provider / endpoint overrides
OPENAI_API_BASE=https://api.openai.com/v1
MINIMAX_API_BASE=https://api.minimaxi.com
GITHUB_API_BASE=https://api.github.com
GITLAB_API_BASE=https://gitlab.com/api/v4

# Minimal platform defaults
GITHUB_REPOSITORY=your-org/marten
CHANNEL_PROVIDER=feishu
MCP_GITHUB_SERVER_NAME=github

# JSON-first config entry points
MCP_CONFIG_PATH=mcp.json
PLATFORM_CONFIG_PATH=platform.json
AGENTS_CONFIG_PATH=agents.json
MODELS_CONFIG_PATH=models.json
