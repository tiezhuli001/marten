APP_ENV=development
APP_NAME=marten
APP_PORT=8000
APP_DATA_DIR=data
DATABASE_URL=sqlite:///data/marten.db

LANGSMITH_TRACING=false
LANGSMITH_PROJECT=marten
LANGSMITH_API_KEY=

# Runtime-only env overrides
# Prefer putting provider and MCP secrets in models.json / mcp.json.
# Keep env for deployment-time overrides, webhook secrets, or path overrides.
CHANNEL_WEBHOOK_URL=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Minimal platform defaults
GITHUB_REPOSITORY=your-org/marten
CHANNEL_PROVIDER=feishu

# JSON-first config entry points
MCP_CONFIG_PATH=mcp.json
PLATFORM_CONFIG_PATH=platform.json
AGENTS_CONFIG_PATH=agents.json
MODELS_CONFIG_PATH=models.json
